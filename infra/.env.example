# Tenant Dynatrace (SaaS trial)
# URL sin barra final. Ejemplo: https://abc12345.live.dynatrace.com
DYNATRACE_ENVIRONMENT_URL=

# ID del environment (prefijo de la URL, ej. abc12345)
DYNATRACE_ENVIRONMENT_ID=

# Token API plataforma (scopes según lab)
DYNATRACE_API_TOKEN=

# Token Dynatrace Operator (Kubernetes app → Add cluster) — M05
DYNATRACE_OPERATOR_TOKEN=

# Token ingest: metrics.ingest, logs.ingest, openTelemetryTrace.ingest — M05
DYNATRACE_INGEST_TOKEN=

# PaaS token para desplegar OneAgent como contenedor Docker — M03
# Crear en: Settings → Access tokens → Generate token → PaaS
ONEAGENT_PAAS_TOKEN=

# Opcional: URL del instalador OneAgent Linux (arch=x86).
# Si vacío, scripts/oneagent-up.sh la construye desde DYNATRACE_ENVIRONMENT_URL
ONEAGENT_INSTALLER_SCRIPT_URL=
